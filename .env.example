# Ollama model to use for replies.
OLLAMA_MODEL=gemma4:e4b

# Optional Ollama context window size. 32768 is 32k tokens.
OLLAMA_CONTEXT_SIZE=32768

# Default markdown personality from the personalities/ folder, without .md.
DEFAULT_PERSONALITY=alex-jones

# Baileys internals are noisy; keep this silent unless debugging connection issues.
BAILEYS_LOG_LEVEL=silent

# App log level: debug, info, warn, error, or silent.
LOG_LEVEL=info
